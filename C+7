#include <stdio.h>
#include <stdlib.h>

void update(int *a, int *b) {
    int old_a = *a;
    int old_b = *b;
    
    // Store the sum in the memory location of 'a'
    *a = old_a + old_b;
    
    // Store the absolute difference in the memory location of 'b'
    *b = abs(old_a - old_b);
}

int main() {
    int a, b;
    int *pa = &a, *pb = &b;
    
    if (scanf("%d %d", &a, &b) == 2) {
        update(pa, pb);
        printf("%d\n%d\n", a, b);
    }
    
    return 0;
}
