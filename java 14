import java.io.*;
import java.util.*;

public class Solution {

    public static int simpleArraySum(int[] ar) {
        int sum = 0;
        for (int num : ar) {
            sum += num;
        }
        return sum;
    }

    public static void main(String[] args) {
        Scanner scan = new Scanner(System.in);
        int n = scan.nextInt();
        int[] ar = new int[n];
        
        for (int i = 0; i < n; i++) {
            ar[i] = scan.nextInt();
        }
        scan.close();

        System.out.println(simpleArraySum(ar));
    }
}
